rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper: Check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if the logged-in user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Check if user is the creator or a player in a game
    function isGameParticipant(gameData) {
      return isAuthenticated() && (
        gameData.createdBy == request.auth.uid || 
        (gameData.playerUids != null && gameData.playerUids.hasAny([request.auth.uid]))
      );
    }

    // Helper: Check if user can read the game (participant or authenticated and non-private)
    function canReadGame(gameData) {
      return isGameParticipant(gameData) || (isAuthenticated() && gameData.get('isPrivate', false) == false);
    }

    // Helper: Check if user can write to the game (must be a participant)
    function canWriteGame(gameData) {
      return isGameParticipant(gameData);
    }

    // Helper: Check if user is a tournament admin for a game's tournament
    function isTournamentAdmin(gameData) {
      return isAuthenticated()
        && gameData.get('tournamentId', '') != ''
        && get(/databases/$(database)/documents/tournaments/$(gameData.tournamentId)).data.adminUids.hasAny([request.auth.uid]);
    }

    // 1. Users collection:
    // - Any logged-in player can search/read player list to start a game.
    // - Only the owner can edit, create, or delete their profile.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Metadata collection:
    // - Any logged-in user can read and write metadata documents (such as tags).
    match /metadata/{metadataId} {
      allow read, write: if isAuthenticated();
    }

    // 2. Games collection:
    // - Any logged-in user can create a game, provided they mark themselves as creator.
    // - Only game participants (or tournament admins) can write/edit/delete.
    // - All authenticated users can read if non-private.
    match /games/{gameId} {
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow read: if canReadGame(resource.data);
      allow update: if canWriteGame(resource.data) || isTournamentAdmin(resource.data);
      allow delete: if canWriteGame(resource.data);

      // 3. Rounds nested subcollection:
      // - Only game participants or tournament admins can write/add/edit. All authenticated users can read if game is non-private.
      match /rounds/{roundId} {
        allow read: if canReadGame(get(/databases/$(database)/documents/games/$(gameId)).data);
        allow write: if canWriteGame(get(/databases/$(database)/documents/games/$(gameId)).data)
          || isTournamentAdmin(get(/databases/$(database)/documents/games/$(gameId)).data);
      }
    }

    // 4. Tournaments collection:
    // - Any authenticated user can read tournaments (public info).
    // - Only authenticated users can create (must include self in adminUids).
    // - Only admins can update/delete.
    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.adminUids.hasAny([request.auth.uid]);
      allow update: if isAuthenticated() && resource.data.adminUids.hasAny([request.auth.uid]);
      allow delete: if isAuthenticated() && resource.data.adminUids.hasAny([request.auth.uid]);

      // Teams subcollection
      match /teams/{teamId} {
        allow read: if isAuthenticated();
        // Create: admin OR (self-register enabled AND user is player1)
        allow create: if isAuthenticated() && (
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.adminUids.hasAny([request.auth.uid])
          || (
            get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.selfRegister == true
            && request.resource.data.player1.uid == request.auth.uid
          )
        );
        // Update: admin OR player in team with account
        allow update: if isAuthenticated() && (
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.adminUids.hasAny([request.auth.uid])
          || resource.data.player1.uid == request.auth.uid
          || resource.data.player2.uid == request.auth.uid
        );
        // Delete: admin OR player1 in team
        allow delete: if isAuthenticated() && (
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.adminUids.hasAny([request.auth.uid])
          || resource.data.player1.uid == request.auth.uid
        );
      }
    }
  }
}

